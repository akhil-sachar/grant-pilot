# Shared local development defaults.
APP_ENV=development
DEMO_MODE=true
CLICKHOUSE_ENABLED=true
CLICKHOUSE_FALLBACK_ENABLED=true

# Frontend
NEXT_PUBLIC_APP_NAME=GrantPilot
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=true

# Backend
CORS_ORIGINS=http://localhost:3000
MOCK_STORAGE_PATH=backend/.data/mock_storage.json
CLICKHOUSE_ENABLED=true
CLICKHOUSE_FALLBACK_ENABLED=true

# Infrastructure integrations are placeholders until real services are connected.
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=grantpilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
AIRBYTE_API_URL=http://localhost:8001/api/public/v1
COMPOSIO_API_KEY=
GUILD_HOME=.guild
OPENUI_URL=http://localhost:7878
