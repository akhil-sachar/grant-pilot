APP_ENV=development
DEMO_MODE=true
CLICKHOUSE_ENABLED=true
CLICKHOUSE_FALLBACK_ENABLED=true
CORS_ORIGINS=http://localhost:3000
MOCK_STORAGE_PATH=backend/.data/mock_storage.json
DOCUMENT_STORAGE_PATH=backend/.data/documents

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=grantpilot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

SPONSOR_SCAN_ENABLED=true
SPONSOR_SCAN_INTERVAL_SECONDS=300

# Grants.gov live API (search2 — no auth required)
GRANTS_GOV_LIVE_ENABLED=true
GRANTS_GOV_API_URL=https://api.grants.gov/v1/api/search2
GRANTS_GOV_SEARCH_ROWS=25
GRANTS_GOV_SEARCH_KEYWORD=education scholarship student
GRANTS_GOV_OPP_STATUSES=forecasted|posted
GRANTS_GOV_SEARCH_AGENCIES=
GRANTS_GOV_FUNDING_CATEGORIES=

NOTIFICATION_SCAN_ENABLED=true
NOTIFICATION_SCAN_INTERVAL_SECONDS=180
COMPOSIO_API_KEY=

# OpenAI + Langfuse (all agents use OpenAI when OPENAI_API_KEY is set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_GENERATION_METHOD=auto
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

GUILD_AI_ENABLED=true
OPENUI_ENABLED=true
DEMO_AUTO_RUN=false
GUILD_HOME=.guild
OPENUI_URL=http://localhost:7878
