{
  "name": "grant-pilot",
  "version": "0.1.0",
  "private": true,
  "description": "GrantPilot hackathon foundation for autonomous scholarship and grant applications.",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
